/* Ensure the save-wiki button in the whiteboard top bar
   matches the size and pill styling of the adjacent buttons */

.lithic-wb-save-btn {
    display: inline-flex;
    align-items: center;
    vertical-align: middle;
    margin: 0 1px;
}

.lithic-wb-save-btn button {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    width: 3.2em !important;
    height: 2.0em !important;
    border-radius: 1.0em !important;
    background: #373d44 !important;
    border: 1px solid rgba(255, 255, 255, 0.2) !important;
    cursor: pointer;
    padding: 0 !important;
    box-sizing: border-box !important;
}

.lithic-wb-save-btn button:hover {
    background: #4a5159 !important; /* Slightly lighter on hover */
}

/* Scale up the SVG icon inside */
.lithic-wb-save-btn button svg {
    width: 1.2em;
    height: 1.2em;
}
