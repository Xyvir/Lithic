title: $:/Lithic/transcludify-search-results
tags: $:/tags/AdvancedSearch/FilterButton
caption: Transcludify Results
description: Create a temporary tiddler that transcludes all results from the current filter

<$reveal state="$:/temp/advancedsearch" type="nomatch" text="">
<$set name="search-input" value={{$:/temp/advancedsearch}}>
<$list filter="[subfilter{$:/temp/advancedsearch}limit[1]]" variable="ignore">
   <$button tooltip="Create a tiddler transcluding these results" class="tc-btn-invisible">
      <$action-setfield 
         $tiddler="$:/TranscludedFilter"
         filter-string=<<search-input>>
         text="<$list filter='[subfilter{!!filter-string}]' template='$:/core/ui/ViewTemplate/body'/>"
         type="text/vnd.tiddlywiki"
      />
      <$action-navigate $to="$:/TranscludedFilter"/>
      {{$:/core/images/transcludify}}
   </$button>
</$list>
</$set>
</$reveal>
