title: $:/lithic/css/katex-mobile

/* Fix KaTeX math overflowing the mobile viewport and breaking the bottom bar layout */
.katex-display {
    max-width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    /* Add a tiny padding so that scrollbars don't clip the bottom of equations */
    padding-bottom: 2px;
}

/* Optional: Scale down math slightly on mobile to reduce the chance of needing the scrollbar */
@media (max-width: 768px) {
    .katex {
        font-size: 0.9em;
    }
}
