title: $:/plugins/lithic/lithic-pdf-to-whiteboard/pdf-drop-handler.js
type: application/javascript
module-type: startup

/* Intercepts PDF file drops and converts them into TLDraw Whiteboard tiddlers. */
(function(){

/*jslint node: true, browser: true */
/*global $tw: false */
"use strict";

exports.name = "pdf-to-whiteboard";
exports.platforms = ["browser"];
exports.after = ["startup"];
exports.synchronous = true;

function generateUUID() {
    if (typeof crypto !== "undefined" && crypto.randomUUID) {
        return crypto.randomUUID();
    }
    // Fallback UUID v4 generator
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
        var r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);
        return v.toString(16);
    });
}

function generateWhiteboardData(images) {
    const documentId = "doc";
    const pages = {};
    const assets = {};
    const pageStates = {};

    images.forEach((img, index) => {
        const i = index + 1;
        
        const uuidAsset = generateUUID();
        const uuidShape = generateUUID();
        // TLDraw v1 expects the first page ID to typically be "page"
        const uuidPage = i === 1 ? "page" : generateUUID();

        // Add page
        pages[uuidPage] = {
            id: uuidPage,
            name: `Page ${i}`,
            childIndex: i,
            shapes: {},
            bindings: {}
        };

        // Add asset
        assets[uuidAsset] = {
            id: uuidAsset,
            type: "image",
            fileName: img.filename,
            src: img.dataUri,
            size: [img.width, img.height]
        };

        // Add shape to page
        pages[uuidPage].shapes[uuidShape] = {
            id: uuidShape,
            type: "image",
            name: "Image",
            parentId: uuidPage,
            childIndex: 1,
            point: [0, 0],
            size: [img.width, img.height],
            rotation: 0,
            style: {
                color: "black",
                size: "small",
                isFilled: false,
                dash: "draw",
                scale: 1
            },
            assetId: uuidAsset,
            isLocked: true
        };

        // Initialize page state
        // Zoom to fit: camera.point in TLDraw v1 is a screen-space offset.
        // Positive values push content right/down, creating visible margins.
        const sidebarMargin = 0; 
        const topMargin = 50;

        // Use actual stream row height (540px) so the image fits within the viewer
        const viewerWidth = 1200;
        const viewerHeight = 540;

        const zoom = Math.min(
            (viewerWidth - sidebarMargin) / img.width,
            (viewerHeight - topMargin) / img.height,
            1
        );

        pageStates[uuidPage] = {
            id: uuidPage,
            selectedIds: [],
            camera: {
                // camera.point is in canvas space, so divide desired screen-pixel
                // margin by zoom to get the correct canvas-unit offset.
                point: [sidebarMargin / zoom, topMargin / zoom],
                zoom: zoom
            }
        };
    });

    return {
        document: {
            id: documentId,
            name: "PDF Canvas",
            version: 15.5,
            pages: pages,
            pageStates: pageStates,
            assets: assets
        }
    };
}

async function convertPdfDataToTiddlers(arrayBuffer, fileName, setProgress) {
    const pdfjsLib = require("$:/plugins/lithic/lithic-pdf-to-whiteboard/pdf.js");
    
    // --- Worker Configuration ---
    if (!globalThis.pdfjsWorker) {
        var workerText = $tw.wiki.getTiddlerText("$:/plugins/lithic/lithic-pdf-to-whiteboard/pdf.worker.js");
        if (workerText) {
            (new Function(workerText))();
        }
    }
    if (pdfjsLib.GlobalWorkerOptions && !pdfjsLib.GlobalWorkerOptions.workerSrc) {
        pdfjsLib.GlobalWorkerOptions.workerSrc = "data:application/javascript,";
    }

    setProgress("Converting " + fileName + " — loading PDF...");
    
    const loadingTask = pdfjsLib.getDocument({ 
        data: arrayBuffer,
        isEvalSupported: false,
        disableStream: true,
        disableAutoFetch: true
    });
    
    const pdf = await loadingTask.promise;
    const images = [];
    var pageTexts = [];

    for (let i = 1; i <= pdf.numPages; i++) {
        setProgress("Converting " + fileName + " — rendering page " + i + "/" + pdf.numPages + "...");

        const page = await pdf.getPage(i);
        const scale = 2.0; 
        const viewport = page.getViewport({ scale: scale });

        const canvas = document.createElement("canvas");
        const context = canvas.getContext("2d");
        canvas.width = viewport.width;
        canvas.height = viewport.height;

        await page.render({ canvasContext: context, viewport: viewport }).promise;

        const dataUri = canvas.toDataURL("image/png");
        images.push({
            filename: "page_" + i + ".png",
            dataUri: dataUri,
            width: viewport.width,
            height: viewport.height
        });

        var textContent = await page.getTextContent();
        var pageText = textContent.items
            .map(function(item) { return item.str; })
            .join(" ")
            .replace(/\s+/g, " ")
            .trim();
        if (pageText) {
            pageTexts.push("#### Page " + i + "\n\n" + pageText);
        }
    }

    const baseName = fileName.replace(/\.pdf$/i, "");
    const containerTitle = $tw.wiki.generateNewTitle(baseName);
    const txtTitle = $tw.wiki.generateNewTitle(containerTitle + "-text");
    const wbTitle = $tw.wiki.generateNewTitle(containerTitle + "-whiteboard");

    const tiddlers = [];
    
    // Container tiddler
    tiddlers.push({
        title: containerTitle,
        "stream-list": $tw.utils.stringifyList([txtTitle, wbTitle]),
        "stream-type": "default",
        text: ""
    });

    // Plaintext markdown tiddler
    var markdownBody = "## " + baseName + "\n\n" + pageTexts.join("\n\n");
    tiddlers.push({
        title: txtTitle,
        parent: containerTitle,
        text: markdownBody,
        type: "text/x-markdown",
        "stream-type": "default"
    });

    // Whiteboard tiddler
    const payload = generateWhiteboardData(images);
    tiddlers.push({
        title: wbTitle,
        parent: containerTitle,
        text: JSON.stringify(payload),
        type: "application/tldr",
        "stream-type": "default"
    });

    return tiddlers;
}

exports.startup = function() {
    var alertTitle = "$:/temp/alerts/pdf-import-progress";
    function setProgress(msg) {
        $tw.wiki.addTiddler(new $tw.Tiddler({
            title: alertTitle,
            text: msg,
            component: "pdf-to-whiteboard",
            tags: "$:/tags/Alert",
            modified: new Date()
        }));
    }
    function clearProgress() {
        $tw.wiki.deleteTiddler(alertTitle);
    }

    async function handleFiles(files, event) {
        const pdfFiles = Array.from(files).filter(f => f.type === "application/pdf" || f.name.toLowerCase().endsWith(".pdf"));
        if (pdfFiles.length > 0) {
            // We found PDFs, so intercept this event completely
            event.preventDefault();
            event.stopPropagation();
            event.stopImmediatePropagation();

            // If it was a drop, dismiss the TW dropzone UI
            if (event.type === "drop") {
                document.dispatchEvent(new DragEvent("dragleave", { bubbles: true }));
            }

            try {
                var createdTitles = [];
                for (const file of pdfFiles) {
                    const arrayBuffer = await file.arrayBuffer();
                    const tiddlers = await convertPdfDataToTiddlers(arrayBuffer, file.name, setProgress);
                    
                    // Add tiddlers to the wiki
                    for (const fields of tiddlers) {
                        $tw.wiki.addTiddler(new $tw.Tiddler(fields));
                        if (!fields.parent) { // It's the container
                            createdTitles.push(fields.title);
                        }
                    }
                }

                clearProgress();

                // Update $:/Import and $:/StoryList
                var importList = createdTitles.map(function(t) { return "# [[" + t + "]]"; }).join("\n");
                $tw.wiki.addTiddler(new $tw.Tiddler(
                    $tw.wiki.getCreationFields(),
                    $tw.wiki.getModificationFields(),
                    {
                        title: "$:/Import",
                        text: "The following tiddlers were imported:\n\n" + importList,
                        status: "complete"
                    }
                ));

                var storyTiddler = $tw.wiki.getTiddler("$:/StoryList");
                var storyList = storyTiddler ? ($tw.utils.parseStringArray(storyTiddler.fields.list) || []) : [];
                storyList = storyList.filter(function(t) { return t !== "$:/Import"; });
                storyList.unshift("$:/Import");
                $tw.wiki.addTiddler(new $tw.Tiddler({
                    title: "$:/StoryList",
                    list: $tw.utils.stringifyList(storyList)
                }));

                // Handle other (non-PDF) files that were part of the same selection
                const otherFiles = Array.from(files).filter(f => !pdfFiles.includes(f));
                if (otherFiles.length > 0) {
                    $tw.utils.each(otherFiles, function(file) {
                        $tw.utils.deserializeTiddlers(file.type, file, {}, function(tiddlers) {
                            $tw.rootWidget.dispatchEvent({type: "tm-import-tiddlers", tiddlers: tiddlers});
                        });
                    });
                }

            } catch (err) {
                clearProgress();
                console.error("PDF Processing error:", err);
                setProgress("Failed to convert PDF: " + err.message);
            }
        }
    }

    // Intercept drops
    document.addEventListener("drop", function(event) {
        if (event.dataTransfer && event.dataTransfer.files && event.dataTransfer.files.length > 0) {
            handleFiles(event.dataTransfer.files, event);
        }
    }, true); 

    // Intercept the native Import button (and any other file inputs)
    document.addEventListener("change", function(event) {
        if (event.target.tagName === "INPUT" && event.target.type === "file" && event.target.files && event.target.files.length > 0) {
            handleFiles(event.target.files, event);
        }
    }, true);
};

})();
