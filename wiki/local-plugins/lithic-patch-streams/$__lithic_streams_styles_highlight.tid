title: $:/lithic/streams/styles/highlight
tags: $:/tags/Stylesheet

.stream-row[data-node-tags~="Highlight"] > .sq-contextmenu-container .stream-node-handle-inner {
    background-color: <<colour primary>>;
    border-color: <<colour primary>>;
}

.stream-row[data-node-tags~="Highlight"] > .stream-node-block {
    border: 1px solid <<colour primary>>;
    border-radius: 4px;
    padding: 2px 6px;
    margin-left: -7px;
    margin-top: -3px;
    margin-bottom: -3px;
}
