modified: 20260125091753965
tags: $:/tags/ViewTemplate $:/tags/Macro
title: $:/plugins/kebi/tiddlystudy-references/filters

\whitespace trim
\whitespace trim
\define generate-list(statetiddler, filter, class)
\whitespace trim
  <$reveal type="match" state="$statetiddler$" text="enable">
    <$list filter="$filter$ -[is[blank]]">
      <li class="$class$">
        <$link to={{!!title}}>
          <$view field="title"/>
        </$link>
      </li>
    </$list>
  </$reveal>
\end

<ul class="footer">
<$vars 
  targetTitle=<<currentTiddler>>
  safeAlias={{{ [enlist{!!aliases}first[]] ~[[$:/no-match-placeholder]] }}} 
  targets={{{ [<currentTiddler>] [enlist{!!aliases}first[]] +[format:titlelist[]join[ ]] }}}
>
<$let 
  lbrack="[[" rbrack="]]" pipe="|"
  hardLinks={{{ [enlist<targets>addprefix<lbrack>addsuffix<rbrack>] [enlist<targets>addprefix<pipe>addsuffix<rbrack>] +[format:titlelist[]join[ ]] }}}
  textBacklinks={{{ [enlist<hardLinks>] :map[all[tiddlers]!is[system]search:text:literal<currentTiddler>] +[format:titlelist[]join[ ]] }}}
  allBacklinks={{{ [enlist<targets>backlinks[]] [enlist<textBacklinks>] +[format:titlelist[]join[ ]] }}}
>
<<generate-list statetiddler:"$:/plugins/kebi/tiddlystudy-references/config/filters/transclusions" filter:"[enlist<targets>backtranscludes[]] -[is[current]] -[is[system]] -[all[shadows]] -[is[image]]" class:"filtertransclude">>
<<generate-list statetiddler:"$:/plugins/kebi/tiddlystudy-references/config/filters/tags" filter:"[enlist<targets>tagging[]] -[enlist<targets>backtranscludes[]] -[is[current]] -[is[system]] -[all[shadows]]" class:"filtertag">>
<<generate-list statetiddler:"$:/plugins/kebi/tiddlystudy-references/config/filters/backlinks" filter:"[enlist<allBacklinks>] -[enlist<targets>backtranscludes[]] -[enlist<targets>tagging[]] -[is[current]] -[is[system]] -[all[shadows]] -[is[image]] +[unique[]]" class:"filterbacklink">>
<<generate-list statetiddler:"$:/plugins/kebi/tiddlystudy-references/config/filters/mentions-title" filter:"[all[tiddlers]!is[system]search:title:literal<targetTitle>] [all[tiddlers]!is[system]search:title:literal<safeAlias>] +[unique[]] -[enlist<allBacklinks>] -[enlist<targets>backtranscludes[]] -[enlist<targets>tagging[]] -[has[parent]] -[is[current]] -[all[shadows]]" class:"filtertitle">>
</$let>
</$vars>
</ul>

<$wikify name="primaryColor" text="<<colour primary>>">
<$let pillStyle={{{ [[background-color:transparent; border:1px solid ]] [<primaryColor>] [[;]] +[join[]] }}}>
<$let 
  streamList={{{ [<currentTiddler>get[parent]get[stream-list]] }}}
  prevTarget={{{ [<currentTiddler>get[prev]] ~[enlist<streamList>before<currentTiddler>] }}}
  nextTarget={{{ [<currentTiddler>get[next]] ~[enlist<streamList>after<currentTiddler>] }}}
>
<$list filter="[<prevTarget>minlength[1]] [<nextTarget>minlength[1]] +[limit[1]]" variable="ignore">
<ul class="footer">
<$list filter="[<prevTarget>minlength[1]]" emptyMessage="<li class='filtertag' style='background-color:gray; opacity:0.5;' title='No previous'>&lt;&lt; Prev</li>" variable="ignore">
<li class="filtertag" style=<<pillStyle>> title=<<prevTarget>>>
<$button class="tc-btn-invisible tc-tiddlylink" tooltip=<<prevTarget>> style="color:inherit; cursor:pointer;">
<$action-navigate $to=<<prevTarget>>/>
<$action-listops $tiddler=<<currentTiddler>> $tags="-Dogear"/>
<$action-listops $tiddler=<<prevTarget>> $tags="Dogear"/>
<$action-sendmessage $message="tm-close-tiddler" $param=<<currentTiddler>>/>
&lt;&lt; Prev
</$button>
</li>
</$list>

<$list filter="[<currentTiddler>tag[Dogear]]" emptyMessage="<li class='filtertag' style='background-color:gray; opacity:0.5;' title='No active dogear'>X</li>" variable="ignore">
<li class="filtertag" style=<<pillStyle>> title="Stop Reading">
<$button class="tc-btn-invisible tc-tiddlylink" tooltip="Stop Reading" style="color:inherit; cursor:pointer;">
<$action-confirm $message="Are you sure you want to stop reading and remove the dogear from this page?">
<$action-listops $tiddler=<<currentTiddler>> $tags="-Dogear"/>
</$action-confirm>
X
</$button>
</li>
</$list>

<$list filter="[<nextTarget>minlength[1]]" emptyMessage="<li class='filtertag' style='background-color:gray; opacity:0.5;' title='No next'>Next &gt;&gt;</li>" variable="ignore">
<li class="filtertag" style=<<pillStyle>> title=<<nextTarget>>>
<$button class="tc-btn-invisible tc-tiddlylink" tooltip=<<nextTarget>> style="color:inherit; cursor:pointer;">
<$action-navigate $to=<<nextTarget>>/>
<$action-listops $tiddler=<<currentTiddler>> $tags="-Dogear"/>
<$action-listops $tiddler=<<nextTarget>> $tags="Dogear"/>
<$action-sendmessage $message="tm-close-tiddler" $param=<<currentTiddler>>/>
Next &gt;&gt;
</$button>
</li>
</$list>
</ul>
</$list>
</$let>
</$let>
</$wikify>
