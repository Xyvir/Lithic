/*\
title: $:/lithic/startup/register-lith-extension.js
type: application/javascript
module-type: startup

Registers the .lith file extension to be handled by the core JSON deserializer.
\*/
(function(){

/*jslint node: true, browser: true */
/*global $tw: false */
"use strict";

// Export name and synchronous status
exports.name = "register-lith-extension";
exports.platforms = ["browser", "node"];
exports.after = ["startup"];
exports.synchronous = true;

exports.startup = function() {
    // Map the custom extension to our custom .lith MIME type
    $tw.config.fileExtensionInfo[".lith"] = { type: "text/vnd.lithic" };
    // Register the content type so TW's import pipeline can resolve it
    $tw.config.contentTypeInfo["text/vnd.lithic"] = { encoding: "utf8", extension: ".lith" };
    // Register the deserializer directly into the boot-time collection
    // (avoids tiddlerdeserializer module-type which forces a reload cycle)
    if($tw.Wiki.tiddlerDeserializerModules) {
        $tw.Wiki.tiddlerDeserializerModules["text/vnd.lithic"] = function(text, fields) {
            var results = [];
            var chunks = text.split(/(?:\r?\n)*\u2042\u2042\u2042(?:\r?\n)*/);
            for(var i = 0; i < chunks.length; i++) {
                var chunk = chunks[i].trim();
                if(!chunk) continue;
                var blankLineMatch = /\r?\n\r?\n/.exec(chunk);
                var headerStr, bodyText;
                if(blankLineMatch) {
                    headerStr = chunk.substring(0, blankLineMatch.index);
                    bodyText = chunk.substring(blankLineMatch.index + blankLineMatch[0].length);
                } else {
                    headerStr = chunk;
                    bodyText = "";
                }
                var tiddlerFields = $tw.utils.parseFields(headerStr);
                if(tiddlerFields) {
                    if(bodyText) {
                        tiddlerFields.text = bodyText;
                    }
                    if(fields) {
                        for(var field in fields) {
                            if(tiddlerFields[field] === undefined) {
                                tiddlerFields[field] = fields[field];
                            }
                        }
                    }
                    results.push(tiddlerFields);
                }
            }
            return results;
        };
    }
};

})();